# agent_community — 仅跟踪自研代码、文档与部署脚本
# 详见 项目整理文档.md §6–§7

# =============================================================================
# 第三方克隆 / 归档区（体积占 99%+，按需 clone 或 submodule）
# =============================================================================
temp/
research_repos/

# =============================================================================
# 运行时 / 本地数据（可重建，勿入库）
# =============================================================================
student_data/
skills_data/
behavior_data/
calibration_data/
proactive_data/
tools_data/
wiki_data/
canvases/
perception_data/

# =============================================================================
# Hermes 插件安装时生成的仓库根标记（install_plugin.sh 写入）
# =============================================================================
**/AGENT_COMMUNITY_ROOT

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.env/
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/
*.cover

# =============================================================================
# 密钥与环境变量（保留 .env.example）
# =============================================================================
.env
.env.*
!.env.example
!**/.env.example

