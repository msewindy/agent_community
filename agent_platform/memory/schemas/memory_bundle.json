      "additionalProperties": false,
      "properties": {
        "record_id": {
          "title": "Record Id",
          "type": "string"
        },
        "device_id": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Device Id",
          "type": "string"
        },
        "ts": {
          "format": "date-time",
          "title": "Ts",
          "type": "string"
