          "default": null,
          "title": "Content Hash"
        },
        "status": {
          "$ref": "#/$defs/MemoryStatus",
          "default": "active"
        },
        "supersedes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
