    "ObserveEvent": {
      "$defs": {
        "ObserveSource": {
          "enum": [
            "cli",
            "chat",
            "voice",
            "demo",
            "reachy"
          ],
          "title": "ObserveSource",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "description": "观测事件 — 进入记忆管道前的统一输入（阶段 A 最小字段）。",
      "properties": {
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "ts": {
          "format": "date-time",
          "title": "Ts",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/ObserveSource",
          "default": "chat"
        },
        "modality": {
          "items": {
            "type": "string"
          },
          "title": "Modality",
          "type": "array"
        },
        "text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Text"
        },
        "payload": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Payload"
        },
        "trace_id": {
          "title": "Trace Id",
          "type": "string"
        },
        "device_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Device Id"
        },
        "entities": {
          "items": {
            "type": "string"
          },
          "title": "Entities",
          "type": "array"
        },
        "scene": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Scene"
        },
        "raw_refs": {
          "items": {
            "type": "string"
          },
          "title": "Raw Refs",
          "type": "array"
        }
      },
      "title": "ObserveEvent",
      "type": "object"
