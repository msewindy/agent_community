{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agent_platform.perception",
  "version": "1.0.0",
  "definitions": {
    "PerceptionPolicy": {
      "additionalProperties": false,
      "description": "User switches — camera/mic not always-on (US-2).",
      "properties": {
        "camera_enabled": {
          "default": false,
          "title": "Camera Enabled",
          "type": "boolean"
        },
        "microphone_enabled": {
          "default": false,
          "title": "Microphone Enabled",
          "type": "boolean"
        },
        "updated_at": {
          "format": "date-time",
          "title": "Updated At",
          "type": "string"
        }
      },
      "title": "PerceptionPolicy",
      "type": "object"
    },
    "PerceptionStatus": {
      "$defs": {
        "PerceptionBackend": {
          "enum": [
            "mock",
            "reachy_sdk"
          ],
          "title": "PerceptionBackend",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "properties": {
        "backend": {
          "$ref": "#/$defs/PerceptionBackend"
        },
        "connected": {
          "default": false,
          "title": "Connected",
          "type": "boolean"
        },
        "reachable": {
          "default": false,
          "title": "Reachable",
          "type": "boolean"
        },
        "sdk_available": {
          "default": false,
          "title": "Sdk Available",
          "type": "boolean"
        },
        "camera_enabled": {
          "default": false,
          "title": "Camera Enabled",
          "type": "boolean"
        },
        "microphone_enabled": {
          "default": false,
          "title": "Microphone Enabled",
          "type": "boolean"
        },
        "message": {
          "default": "",
          "title": "Message",
          "type": "string"
        },
        "details": {
          "additionalProperties": true,
          "title": "Details",
          "type": "object"
        }
      },
      "required": [
        "backend"
      ],
      "title": "PerceptionStatus",
      "type": "object"
    },
    "CaptureRequest": {
      "$defs": {
        "PerceptionModality": {
          "enum": [
            "vision",
            "audio",
            "proprioception"
          ],
          "title": "PerceptionModality",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "description": "Request one perception capture → ObserveEvent.",
      "properties": {
        "modality": {
          "$ref": "#/$defs/PerceptionModality",
          "default": "vision"
        },
        "trace_id": {
          "title": "Trace Id",
          "type": "string"
        },
        "device_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Device Id"
        },
        "scene": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Scene"
        },
        "save_frame": {
          "default": true,
          "title": "Save Frame",
          "type": "boolean"
        },
        "force": {
          "default": false,
          "title": "Force",
          "type": "boolean"
        }
      },
      "title": "CaptureRequest",
      "type": "object"
    },
    "CaptureResult": {
      "$defs": {
        "ObserveEvent": {
          "additionalProperties": false,
          "description": "观测事件 — 进入记忆管道前的统一输入（阶段 A 最小字段）。",
          "properties": {
            "event_id": {
              "title": "Event Id",
              "type": "string"
            },
            "ts": {
              "format": "date-time",
              "title": "Ts",
              "type": "string"
            },
            "source": {
              "$ref": "#/$defs/ObserveSource",
              "default": "chat"
            },
            "modality": {
              "items": {
                "type": "string"
              },
              "title": "Modality",
              "type": "array"
            },
            "text": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Text"
            },
            "payload": {
              "anyOf": [
                {
                  "additionalProperties": true,
                  "type": "object"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Payload"
            },
            "trace_id": {
              "title": "Trace Id",
              "type": "string"
            },
            "device_id": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Device Id"
            },
            "entities": {
              "items": {
                "type": "string"
              },
              "title": "Entities",
              "type": "array"
            },
            "scene": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Scene"
            },
            "raw_refs": {
              "items": {
                "type": "string"
              },
              "title": "Raw Refs",
              "type": "array"
            }
          },
          "title": "ObserveEvent",
          "type": "object"
        },
        "ObserveSource": {
          "enum": [
            "cli",
            "chat",
            "voice",
            "demo",
            "reachy"
          ],
          "title": "ObserveSource",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "properties": {
        "allowed": {
          "title": "Allowed",
          "type": "boolean"
        },
        "reason_code": {
          "default": "ok",
          "title": "Reason Code",
          "type": "string"
        },
        "event": {
          "anyOf": [
            {
              "$ref": "#/$defs/ObserveEvent"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "frame_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Frame Path"
        },
        "message": {
          "default": "",
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "allowed"
      ],
      "title": "CaptureResult",
      "type": "object"
    },
    "PerceptionStoreLayout": {
      "additionalProperties": false,
      "properties": {
        "root": {
          "type": "string"
        },
        "policy_path": {
          "type": "string"
        },
        "captures_dir": {
          "type": "string"
        },
        "events_log_path": {
          "type": "string"
        }
      },
      "required": [
        "root",
        "policy_path",
        "captures_dir",
        "events_log_path"
      ],
      "title": "PerceptionStoreLayout",
      "type": "object"
    }
  }
}
